APP_NAME="Business Partner"
APP_ENV=local
# php artisan key:generate — una clave DISTINTA por entorno, nunca reusar
APP_KEY=
# [PROD] false SIEMPRE: en true, cualquier error muestra el stack trace con
# rutas, consultas y fragmentos del .env
APP_DEBUG=true
# [PROD] https://tudominio.com — sin barra final
APP_URL=http://localhost
 
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR
 
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
 
# ── LOGS ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
# [PROD] daily — rota por dia en vez de un archivo que crece sin fin
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# [PROD] warning — debug llena el disco y filtra datos a los logs
LOG_LEVEL=debug
 
# ── BASE DE DATOS ──────────────────────────────────────────────────────────
# Usuario de la APP: solo SELECT/INSERT/UPDATE/DELETE, sin DDL.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
 
# Usuario de DEPLOY (con DDL, para php artisan migrate --database=mysql_deploy).
#
# NO completar estas dos en el .env del servidor: si el archivo se filtra,
# entregarian un usuario capaz de borrar tablas. Se pasan en la linea de
# comando solo al migrar:
#
#   DB_DEPLOY_USERNAME=xxx DB_DEPLOY_PASSWORD=yyy php artisan migrate --database=mysql_deploy
#
# DB_DEPLOY_USERNAME=
# DB_DEPLOY_PASSWORD=
 
# ── SESION Y AUTENTICACION ─────────────────────────────────────────────────
# Si estas tres no coinciden con el dominio real, NADIE puede loguearse.
# Es el error mas comun al pasar a produccion.
 
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_PATH=/
 
# [PROD] tudominio.com — vacio en local
SESSION_DOMAIN=
 
# [PROD] tudominio.com,www.tudominio.com — sin protocolo ni puerto.
# Si falta, Sanctum no considera "stateful" al dominio y la cookie no autentica.
SANCTUM_STATEFUL_DOMAINS=localhost
 
# OJO: config/session.php tiene default true (fail-secure), PERO ese default
# solo aplica si la variable NO EXISTE. Dejarla presente y vacia la resuelve
# como false y la cookie sale SIN el flag Secure.
# Local (XAMPP, HTTP): false, si no el navegador no la manda.
# [PROD] true.
SESSION_SECURE_COOKIE=false
 
# [PROD] true — cifra el contenido de la sesion ademas de firmarlo.
SESSION_ENCRYPT=false
 
# ── FRONTEND ───────────────────────────────────────────────────────────────
# URL base del frontend. Es la que arma los botones de los mails: si queda en
# localhost, los links no le sirven a nadie.
# [PROD] https://tudominio.com (sin el subpath: el DocumentRoot apunta a public/)
FRONTEND_URL=http://localhost/manuales-franquiciantes/public
 
# ── ARCHIVOS ───────────────────────────────────────────────────────────────
# [PROD] s3 — con 'local' los archivos van al disco de la instancia, que en
# varios entornos es efimero: se pierden en el proximo deploy.
FILESYSTEM_DISK=local
 
# Solo en produccion. El bucket va PRIVADO: todo se sirve por endpoints
# autenticados, nunca por URL directa.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
 
# ── COLAS Y CACHE ──────────────────────────────────────────────────────────
# database necesita un worker corriendo:
#     php artisan queue:work --tries=3 --timeout=90
# supervisado. SIN worker los mails quedan encolados y NO SALEN NUNCA, sin
# ningun error visible.
QUEUE_CONNECTION=database
 
# database y no file: el rate limiter del login guarda ahi su contador, y con
# 'file' cada instancia lleva el suyo (el limite efectivo se multiplica).
CACHE_STORE=database
 
BROADCAST_CONNECTION=log
 
# ── MAIL ───────────────────────────────────────────────────────────────────
# Local: log — los mails se escriben en storage/logs en vez de enviarse.
# [PROD] resend
MAIL_MAILER=log
 
# [PROD] obligatoria con MAIL_MAILER=resend
RESEND_API_KEY=
 
# Tiene que ser de un dominio VERIFICADO en Resend (SPF/DKIM). No se puede
# enviar desde gmail.com.
MAIL_FROM_ADDRESS="noreply@goharv.com.ar"
MAIL_FROM_NAME="${APP_NAME}"
 
VITE_APP_NAME="${APP_NAME}"